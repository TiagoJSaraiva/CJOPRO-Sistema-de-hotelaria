{
  "name": "@hotel/booking-engine-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"No lint configured for @hotel/booking-engine-service\"",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@hotel/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "fastify": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.8.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
