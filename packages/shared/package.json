{
  "name": "@hotel/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "pnpm run build",
    "dev": "tsup src/index.ts --watch --format esm --dts --clean",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"No lint configured for @hotel/shared\"",
    "clean": "rimraf dist",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run __tests__/unit --passWithNoTests",
    "test:integration": "vitest run __tests__/integration --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:watch": "vitest --watch --passWithNoTests"
  },
  "devDependencies": {
    "@types/node": "^22.8.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.0"
  }
}
